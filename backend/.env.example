# --- Application Settings ---

# The name of the project, used in OpenAPI docs and titles.
PROJECT_NAME=FastAPI PostgreSQL Boilerplate

# The environment the application is running in (e.g., local, staging, production).
# Useful for toggling debug modes or environment-specific features.
ENVIRONMENT=local

# --- Security Settings ---

# The secret key used to securely sign JWT tokens for authentication.
# IMPORTANT: You must change this in production to a strong, random value!
SECRET_KEY=change-this-secret-key

# The expiration time in minutes for JWT access tokens.
# 1440 minutes = 24 hours. Adjust this based on your security requirements.
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Database Settings ---

# The hostname or IP address of the PostgreSQL server.
# Use 'localhost' if running the database locally.
POSTGRES_SERVER=localhost

# The port PostgreSQL is listening on (default is 5432).
POSTGRES_PORT=5432

# The username to connect to the PostgreSQL database.
POSTGRES_USER=postgres

# The password to connect to the PostgreSQL database.
POSTGRES_PASSWORD=postgres

# The name of the PostgreSQL database to use for the application.
POSTGRES_DB=app_db

# --- Email Settings ---

MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
MAIL_PORT=587
MAIL_SERVER=
MAIL_FROM_NAME=Auth API
MAIL_STARTTLS=True
MAIL_SSL_TLS=False

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_CURRENCY=INR
